<div class="container mt-5">
  <div class="card shadow" style="width: 40rem; margin: 0 auto; background-color: #f8f9fa;">
    <div class="card-body">
      <h1 class="card-title text-center text-primary">New Task</h1>

      <%= form_with model: @task, local: true do |form| %>
  
        <div class="mb-3">
          <%= form.label :title, "Task Title", class: "form-label text-secondary" %>
          <%= form.text_field :title, class: "form-control", placeholder: "Enter task title", required: true %>
        </div>

        <div class="mb-3">
          <%= form.label :description, "Task Description", class: "form-label text-secondary" %>
          <%= form.text_area :description, class: "form-control", rows: 5, placeholder: "Describe the task in detail" %>
        </div>

        <div class="form-check mb-3">
          <%= form.check_box :completed, class: "form-check-input", id: "task_completed" %>
          <%= form.label :completed, "Completed?", class: "form-check-label", for: "task_completed" %>
        </div>

        <div class="mb-3">
          <%= form.label :date, "Due Date", class: "form-label text-secondary" %>
          <%= form.datetime_select :date, class: "form-control" %>
        </div>

        <div class="d-grid">
          <%= form.submit "Create Task", class: "btn btn-primary" %>
        </div>
      <% end %>

      <div class="mt-3 text-center">
        <%= link_to "Back to Task List", tasks_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>
