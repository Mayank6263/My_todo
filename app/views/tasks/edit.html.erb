<h1>Tasks#edit</h1>
<h1>Edit Task</h1>


<%= form_with model: @task, url: task_path(@task), method: :patch, local: true do |form| %>
  <div>
    <%= form.label :title %><br>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div>
    <%= form.label :description %><br>
    <%= form.text_field :description, class: "form-control" %>
  </div>

  <div>
    <%= form.label :date, "Due Date" %><br>
    <%= form.datetime_field :date, class: "form-control" %>
  </div>

  <div>
    <%= form.label :completed %><br>
    <%= form.check_box :completed %>
  </div>

  <br>
  <div>
    <%= form.submit "Update Task", class: "btn btn-primary" %>
    <%= link_to "Cancel", tasks_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<%= link_to "Back to Task List", tasks_path %>


